workflow draft-release-notes {
  meta {
    description = "Analyze a PR and produce a draft release notes entry"
    trigger     = "manual"
    targets     = ["pr"]
    group       = "Release"
  }

  script fetch-pr-context {
    run = ".conductor/scripts/fetch-pr-context.sh"
    as  = "actor"
    env = { PR_NUMBER = "{{pr_number}}" }
  }
  call draft-release-notes
}
