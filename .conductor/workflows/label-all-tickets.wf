workflow label-all-tickets {
  meta {
    title       = "Label All Tickets"
    description = "Add appropriate labels to all unlabeled open GitHub issues in a repo"
    trigger     = "manual"
    targets     = ["repo"]
    group       = "Analysis"
  }

  foreach label-tickets {
    over         = tickets
    scope        = { unlabeled = true }
    max_parallel = 3
    workflow     = "label-ticket"
    inputs       = { ticket_id = "{{item.id}}" }
    on_child_fail = continue
  }
}
