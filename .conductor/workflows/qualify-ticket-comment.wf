workflow qualify-ticket-comment {
  meta {
    title       = "Qualify Ticket (Comment)"
    description = "Assess a single ticket for autonomous executability and post a GitHub comment with the verdict"
    trigger     = "manual"
    targets     = ["ticket"]
    group       = "Analysis"
  }

  inputs {
    ticket_id required
  }

  call fetch-ticket-context
  call assess-ticket-readiness
  script comment-ticket-assessment {
    run = ".conductor/scripts/comment-ticket-assessment.sh"
    env = {
      PRIOR_OUTPUT     = "{{prior_output}}"
      TICKET_URL       = "{{ticket_url}}"
      TICKET_SOURCE_ID = "{{ticket_source_id}}"
    }
  }
}
