workflow analyze-repo-for-agents {
  meta {
    title       = "Analyze Repo for AI Agents"
    description = "Analyze a repo for large files and produce AI-optimized refactor recommendations"
    trigger     = "manual"
    targets     = ["repo"]
    group       = "Analysis"
  }

  inputs {
    repo            required
    threshold_lines default = "1500"
    focus           default = ""
  }

  script collect-file-sizes {
    run = ".conductor/scripts/collect-file-sizes.sh"
    env = { FOCUS = "{{focus}}" THRESHOLD_LINES = "{{threshold_lines}}" }
  }
  call identify-large-files

  if identify-large-files.has_large_files {
    call analyze-file-structure { retries = 1 }
    call synthesize-repo-report

    if analyze-file-structure.has_split_recommendations {
      gate human_approval {
        prompt     = "Review the report above. Approve to create GitHub issues for the high-priority refactoring recommendations, or reject to finish without filing issues."
        timeout    = "48h"
        on_timeout = continue
      }
      call create-repo-issues
    }
  }

  unless identify-large-files.has_large_files {
    call synthesize-repo-report
  }
}
