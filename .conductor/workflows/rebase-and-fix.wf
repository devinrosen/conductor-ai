workflow rebase-and-fix {
  meta {
    title       = "Rebase & Fix"
    description = "Fetch latest base branch, resolve conflicts, fix lint, and push — leaves the PR CI-green and ready for next steps"
    trigger     = "manual"
    targets     = ["worktree"]
    group       = "Development"
  }

  call workflow rebase-worktree

  call workflow lint-fix
}
