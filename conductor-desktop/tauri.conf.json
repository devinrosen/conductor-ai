{
  "productName": "Conductor",
  "version": "0.1.0",
  "identifier": "ai.conductor.desktop",
  "build": {
    "frontendDist": "../conductor-web/frontend/dist",
    "devUrl": "http://localhost:8675",
    "beforeDevCommand": "bun install --cwd conductor-web/frontend && bun run --cwd conductor-web/frontend dev",
    "beforeBuildCommand": "bun --cwd conductor-web/frontend run build"
  },
  "app": {
    "windows": [
      {
        "title": "Conductor",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:* http://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
