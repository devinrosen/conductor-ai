#!/bin/sh
# Pre-push hook: run Playwright E2E tests when conductor-web files change.
# Enable with: git config core.hooksPath .githooks
# Skip with:   SKIP_E2E=1 git push

set -e

if [ "${SKIP_E2E:-0}" = "1" ]; then
  echo "info: SKIP_E2E=1 — skipping Playwright E2E tests." >&2
  exit 0
fi

# Check whether any conductor-web files are in the commits being pushed.
remote="$1"
url="$2"

# Check whether any ref in the push batch touches conductor-web/.
# We evaluate every ref independently so that a multi-ref push (e.g. git push
# --all) doesn't silently skip E2E tests because the last ref happens not to
# modify conductor-web/.
has_web_changes=0
while read local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    # New branch: compare against the merge base with main.
    base=$(git merge-base HEAD origin/main 2>/dev/null || echo "")
    if [ -n "$base" ]; then
      ref_range="$base..$local_sha"
    else
      ref_range="$local_sha"
    fi
  else
    ref_range="$remote_sha..$local_sha"
  fi
  if git diff --name-only "$ref_range" 2>/dev/null | grep -q '^conductor-web/'; then
    has_web_changes=1
    break
  fi
done

if [ "$has_web_changes" = "0" ]; then
  exit 0
fi

FRONTEND_DIR="conductor-web/frontend"

if [ ! -d "$FRONTEND_DIR/node_modules" ]; then
  echo "error: $FRONTEND_DIR/node_modules not found." >&2
  echo "Run: cd $FRONTEND_DIR && bun install" >&2
  exit 1
fi

if [ ! -f "target/debug/conductor-web" ]; then
  echo "info: building conductor-web binary for E2E tests..." >&2
  cargo build --bin conductor-web
fi

echo "info: running Playwright E2E tests (SKIP_E2E=1 to skip)..." >&2
cd "$FRONTEND_DIR"

# Guard: only install browsers when the Playwright version has changed since
# the last install, avoiding the overhead of --with-deps on every push.
PLAYWRIGHT_VER=$(bunx playwright --version 2>/dev/null | awk '{print $2}')
STAMP_FILE="node_modules/.playwright-installed-${PLAYWRIGHT_VER}"
if [ ! -f "$STAMP_FILE" ]; then
  echo "info: installing Playwright browsers (first run or version change)..." >&2
  bunx playwright install --with-deps chromium webkit >/dev/null 2>&1
  touch "$STAMP_FILE"
fi

bun run test:e2e
